# ============================================================
#  .gitignore — K-Means Hardware Accelerator
#  Keeps repo clean — only source files are tracked
# ============================================================

# ── Vivado generated directories ──
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/utils_1/
*.xpr.bak
*.jou
*.log
*.str

# ── Vivado simulation output ──
xsim.dir/
*.pb
*.wdb
*.wcfg
*.vcd

# ── Vivado synthesis & implementation ──
*.bit
*.ltx
*.dcp
*.rpt
*.xml
*.html
*.xdc

# ── Vivado project backup files ──
*.bak
*.zip
*.tar.gz
*_bak/
*_backup/

# ── Vivado IP output ──
*.xci
*.xcix
ip/

# ── Vivado generated Tcl scripts (auto) ──
*.tcl
!scripts/*.tcl

# ── Python cache ──
__pycache__/
*.pyc
*.pyo
*.pyd
.env
venv/

# ── Generated memory files (re-generated by export_mem.py) ──
# Comment these out if you want to include sample .mem files
pixels.mem
centroids.mem

# ── Validation output image ──
validation_result.png

# ── OS junk ──
.DS_Store
Thumbs.db
desktop.ini

# ── Editor files ──
.vscode/
.idea/
*.swp
*.swo